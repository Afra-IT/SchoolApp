@model IEnumerable<Sepideh1.Models.Teacher>

@{
    ViewData["Title"] = "Teachers";
}

<h1>Teachers</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>First name</th>
            <th>Last name</th>
            <th>Email</th>
            <th>Hire date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var teacher in Model)
{
        <tr>
            <td>@teacher.Id</td>
            <td>@teacher.FirstName</td>
            <td>@teacher.LastName</td>
            <td>@teacher.Email</td>
            <td>@teacher.HireDate.ToString("yyyy-MM-dd")</td>
            <td>
                <a asp-action="Details" asp-route-id="@teacher.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@teacher.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@teacher.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
